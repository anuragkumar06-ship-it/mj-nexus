# ============================================================
# MJ NEXUS — Environment variables
# Copy this file to .env.local and fill in the values to go LIVE.
# With these blank, the app runs in fully-working DEMO mode.
# NEVER commit .env.local (it is gitignored).
# ============================================================

# ---------- Supabase: database, auth & storage ----------
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server-only, NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# ---------- AI layer: OpenAI or Gemini ----------
# AI_PROVIDER = openai | gemini   (default: openai)
# 👉 FREE option: use Gemini. Set AI_PROVIDER=gemini and add GEMINI_API_KEY below.
AI_PROVIDER=gemini
# OpenAI (paid): https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Gemini (has a FREE tier): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---------- App ----------
# Public base URL (used for OAuth redirects). Use your deployed URL in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
